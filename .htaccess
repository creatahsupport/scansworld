Options +FollowSymLinks -MultiViews
AcceptPathInfo Off

# Deny access to .env and other sensitive dotfiles
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Deny access to Composer/dependency files, logs, and backups
<FilesMatch "^(composer\.json|composer\.lock|package\.json|package-lock\.json|error_log|scansworld\.zip|.*\.bak|.*\.sql)$">
    Order allow,deny
    Deny from all
</FilesMatch>


<IfModule mod_rewrite.c>
    RewriteEngine On

    # Force HTTPS if not already using HTTPS (but only once)
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # Redirect invalid ?p= query strings to 404 (Local)
    RewriteCond %{QUERY_STRING} (^|&)p= [NC]
    RewriteCond %{REQUEST_URI} ^/scansworld/ [NC]
    RewriteRule ^(.*)$ /scansworld/404? [R=302,L]

    # Redirect invalid ?p= query strings to 404 (Live)
    RewriteCond %{QUERY_STRING} (^|&)p= [NC]
    RewriteCond %{REQUEST_URI} !^/scansworld/ [NC]
    RewriteRule ^(.*)$ /404? [R=302,L]

    # Prevent rewrite loop by excluding already rewritten URLs (e.g., *.php)
    RewriteCond %{REQUEST_URI} !\.php$

    # If the request is not for an existing directory, rewrite to .php only if a PHP file exists
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^([^/]+)$ $1.php [L,QSA]

    # Rule for blog with non-numeric slug (e.g., /blog/slug)
      RewriteRule ^blog_category/page/([0-9]+)/?$  blog_category.php?page=$1 [NC,QSA,L]
    RewriteRule ^blog/([^/]+)/page/([0-9]+)/?$ blog.php?bids=$1&page=$2 [NC,QSA,L]
    RewriteRule ^blog/([^/]+)/?$ blog.php?bids=$1 [NC,QSA,L]
    RewriteRule ^blog/page/([0-9]+)/?$  blog.php?page=$1 [NC,QSA,L] 
    RewriteRule ^blog-details/([^/]+)/?$ blog-details.php?bid=$1 [NC,QSA,L]
    RewriteRule ^blog_search/([^/]+)$ blog_search.php?q=$1 [L,QSA]
    RewriteRule ^blog_search/([^/]+)/page/([0-9]+)/?$ blog_search.php?q=$1&page=$2 [NC,QSA,L]
    RewriteRule ^gallery/page/([0-9]+)/?$  gallery.php?page=$1 [NC,QSA,L]
    RewriteRule ^testimonials/page/([0-9]+)/?$  testimonials.php?page=$1 [NC,QSA,L]
    RewriteRule ^news-and-events/page/([0-9]+)/?$  news-and-events.php?page=$1 [NC,QSA,L]
    RewriteRule ^news-and-events/([^/]+)/?$ news-and-events-details.php?slug=$1 [NC,QSA,L]
    RewriteRule ^our-doctors/([^/]+)/?$ doctor_details.php?slugs=$1 [NC,QSA,L]
    RewriteRule ^our-doctors/page/([0-9]+)/?$  our-doctors.php?page=$1 [NC,QSA,L]
    RewriteRule ^publications/page/([0-9]+)/?$  publications.php?page=$1 [NC,QSA,L]
    RewriteRule ^publications/([^/]+)/?$ publication_details.php?bids=$1 [NC,QSA,L]
    
    RewriteRule ^book-appointment-thanks/([0-9]+)$ book-appointment-thanks.php?id=$1 [NC,QSA,L]

    # Custom 404 Redirect (Works perfectly on local subdirectories and live)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    # Avoid infinite loop with 404.php itself
    RewriteCond %{REQUEST_URI} !/404(\.php)?$ [NC]
    # Exclude asset requests from triggering the heavy PHP 404 page
    RewriteCond %{REQUEST_URI} !\.gif$ [NC]
    RewriteCond %{REQUEST_URI} !\.jpe?g$ [NC]
    RewriteCond %{REQUEST_URI} !\.png$ [NC]
    RewriteCond %{REQUEST_URI} !\.css$ [NC]
    RewriteCond %{REQUEST_URI} !\.js$ [NC]
    RewriteCond %{REQUEST_URI} !\.svg$ [NC]
    RewriteCond %{REQUEST_URI} !\.webp$ [NC]
    RewriteCond %{REQUEST_URI} !\.ico$ [NC]
    # If in local scansworld subfolder, redirect to the clean web path
    RewriteCond %{REQUEST_URI} ^/scansworld/ [NC]
    RewriteRule ^(.*)$ /scansworld/404 [R=302,L]

    # Live Server Root Redirect (If NOT in local scansworld subfolder)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !/404(\.php)?$ [NC]
    RewriteCond %{REQUEST_URI} !\.gif$ [NC]
    RewriteCond %{REQUEST_URI} !\.jpe?g$ [NC]
    RewriteCond %{REQUEST_URI} !\.png$ [NC]
    RewriteCond %{REQUEST_URI} !\.css$ [NC]
    RewriteCond %{REQUEST_URI} !\.js$ [NC]
    RewriteCond %{REQUEST_URI} !\.svg$ [NC]
    RewriteCond %{REQUEST_URI} !\.webp$ [NC]
    RewriteCond %{REQUEST_URI} !\.ico$ [NC]
    RewriteCond %{REQUEST_URI} !^/scansworld/ [NC]
    RewriteRule ^(.*)$ /404 [R=302,L]

</IfModule>

