# -------------------------------------------------------
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to version control.
# -------------------------------------------------------

# Database
DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_db_username
DB_PASS=your_db_password

# Cloudflare Turnstile (https://dash.cloudflare.com/)
TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# SMTP Mail Settings
SMTP_HOST=your_smtp_host
SMTP_USERNAME=your_smtp_email@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_SETFROM=your_smtp_email@example.com
To_Email=admin_recipient@example.com
MAIL_PORT=123
